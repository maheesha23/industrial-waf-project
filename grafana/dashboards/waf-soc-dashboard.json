{
  "uid": "waf-soc",
  "title": "WAF SOC Overview",
  "tags": ["waf", "soc", "modsecurity", "loki"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Log Source",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(job)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "status",
        "label": "Status Code",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(status)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "attack_type",
        "label": "Attack Type",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(attack_type)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "client_ip",
        "label": "Source IP",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(client_ip)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "rule_id",
        "label": "Rule ID",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(rule_id)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "uri",
        "label": "URL",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(uri)",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"waf-access\", status=~\"$status\", client_ip=~\"$client_ip\", uri=~\"$uri\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1f9d55",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 100
              },
              {
                "color": "#dc2626",
                "value": 500
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Allowed Requests",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"waf-access\", status=\"200\", client_ip=~\"$client_ip\", uri=~\"$uri\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#dc2626",
                "value": null
              },
              {
                "color": "#1f9d55",
                "value": 1
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Blocked Requests",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"modsecurity\", status=~\"$status\", client_ip=~\"$client_ip\", rule_id=~\"$rule_id\", uri=~\"$uri\", attack_type=~\"$attack_type\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1f9d55",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 10
              },
              {
                "color": "#dc2626",
                "value": 50
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Unique Attackers",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (client_ip) (count_over_time({job=\"modsecurity\", client_ip=~\"$client_ip\", attack_type=~\"$attack_type\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1f9d55",
                "value": null
              },
              {
                "color": "#dc2626",
                "value": 1
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },
    {
      "type": "bargauge",
      "title": "Attack Families",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (attack_type) (count_over_time({job=\"modsecurity\", attack_type=~\"$attack_type\", client_ip=~\"$client_ip\", rule_id=~\"$rule_id\", uri=~\"$uri\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "type": "bargauge",
      "title": "Top Attacker IPs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum by (client_ip) (count_over_time({job=\"modsecurity\", client_ip=~\"$client_ip\", attack_type=~\"$attack_type\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "type": "table",
      "title": "Latest Blocked Requests",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"modsecurity\", status=~\"$status\", client_ip=~\"$client_ip\", rule_id=~\"$rule_id\", uri=~\"$uri\", attack_type=~\"$attack_type\"}",
          "queryType": "range"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "line": true,
              "job": true,
              "app": true
            },
            "indexByName": {
              "Time": 0,
              "client_ip": 1,
              "attack_type": 2,
              "rule_id": 3,
              "uri": 4,
              "status": 5,
              "event_type": 6
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#1f9d55",
                      "value": null
                    },
                    {
                      "color": "#f59e0b",
                      "value": 300
                    },
                    {
                      "color": "#dc2626",
                      "value": 400
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "client_ip"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Filter by source IP",
                    "url": "/d/waf-soc/waf-soc-overview?orgId=1&var-client_ip=${__value.raw}&var-job=modsecurity"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rule_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Filter by rule ID",
                    "url": "/d/waf-soc/waf-soc-overview?orgId=1&var-rule_id=${__value.raw}&var-job=modsecurity"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "uri"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Filter by URL",
                    "url": "/d/waf-soc/waf-soc-overview?orgId=1&var-uri=${__value.raw}&var-job=modsecurity"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 18
      }
    },
    {
      "type": "table",
      "title": "Latest Allowed Requests",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"waf-access\", status=~\"$status\", client_ip=~\"$client_ip\", uri=~\"$uri\"}",
          "queryType": "range"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "line": true,
              "job": true,
              "app": true
            },
            "indexByName": {
              "Time": 0,
              "client_ip": 1,
              "method": 2,
              "uri": 3,
              "status": 4,
              "event_type": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#1f9d55",
                      "value": null
                    },
                    {
                      "color": "#f59e0b",
                      "value": 300
                    },
                    {
                      "color": "#dc2626",
                      "value": 400
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 30
      }
    }
  ]
}